@@ -0,0 +1,101 @@
+import { useEffect, useRef } from 'react'
+import './matrix.css'
+
+const COLS = 5
+const ROWS = 5
+
+/**
+ * Audio-reactive 5-bar VU on the 5×5 grid.
+ * Reads an AnalyserNode each frame and lights dots bottom-up;
+ * falls back to gentle synthetic motion when no analyser exists.
+ * Dot opacities are mutated imperatively — no per-frame React renders.
+ */
+function MatrixVisualizer({
+  analyser = null,
+  dotSize = 22,
+  gap = 14,
+  color = '#e4e2da',
+  opBase = 0.13,
+  opPeak = 1,
+}) {
+  const dotRefs = useRef([])
+  const levelsRef = useRef([0, 0, 0, 0, 0])
+
+  useEffect(() => {
+    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
+    let rafId = 0
+    const freqData = analyser ? new Uint8Array(analyser.frequencyBinCount) : null
+    const levels = levelsRef.current
+
+    const paint = () => {
+      for (let c = 0; c < COLS; c++) {
+        const lit = Math.round(levels[c])
+        for (let r = 0; r < ROWS; r++) {
+          const dot = dotRefs.current[r * COLS + c]
+          if (!dot) continue
+          // light from the bottom row upward
+          const on = ROWS - r <= lit
+          dot.style.opacity = on ? opPeak : opBase
+        }
+      }
+    }
+
+    if (reduceMotion) {
+      // static mid-level bars
+      levels.fill(2)
+      levels[2] = 3
+      paint()
+      return undefined
+    }
+
+    const tick = (now) => {
+      if (analyser && freqData) {
+        analyser.getByteFrequencyData(freqData)
+        // voice energy lives in the low bins — 4 bins per column
+        for (let c = 0; c < COLS; c++) {
+          let sum = 0
+          for (let k = 0; k < 4; k++) sum += freqData[c * 4 + k]
+          const raw = Math.min(1, (sum / 4 / 255) * 1.9)
+          const target = Math.pow(raw, 0.75) * ROWS
+          // fast attack, slow release
+          levels[c] = target > levels[c] ? target : levels[c] * 0.82
+        }
+      } else {
+        // synthetic fallback — slow independent column drift
+        for (let c = 0; c < COLS; c++) {
+          levels[c] = 1.6 + 1.6 * Math.abs(Math.sin(now / (430 + c * 117) + c))
+        }
+      }
+      paint()
+      rafId = window.requestAnimationFrame(tick)
+    }
+
+    rafId = window.requestAnimationFrame(tick)
+    return () => window.cancelAnimationFrame(rafId)
+  }, [analyser, opBase, opPeak])
+
+  return (
+    <div
+      className="dmx-grid"
+      style={{
+        '--ds': `${dotSize}px`,
+        '--dg': `${gap}px`,
+        '--dc': color,
+      }}
+      aria-hidden="true"
+    >
+      {Array.from({ length: COLS * ROWS }, (_, i) => (
+        <span
+          key={i}
+          ref={(el) => {
+            dotRefs.current[i] = el
+          }}
+          className="dmx-dot"
+          style={{ opacity: opBase }}
+        />
+      ))}
+    </div>
+  )
+}
+
+export default MatrixVisualizer
