+def plan_wikipedia_retrieval(
+    message: str,
+    history: list[ChatMessage],
+    model: str,
+) -> dict[str, object]:
+    """Planner-first resolution for follow-ups, with the rule-based resolver
+    as the deterministic fallback. Standalone questions never touch the
+    planner, which keeps Scenario C/D behavior deterministic and avoids an
+    extra model call."""
+    rule_resolution = build_wikipedia_context_resolution(message, history)
+    resolution: dict[str, object] = {
+        "is_follow_up": rule_resolution["is_follow_up"],
+        "active_topic": rule_resolution["active_topic"],
+        "retrieval_query": str(rule_resolution["retrieval_query"]),
+        "retrieval_queries": [str(rule_resolution["retrieval_query"])],
+        "reason": rule_resolution["reason"],
+        "standalone_question": message,
+        "active_entities": [],
+        "planner_used": False,
+    }
+
+    if not rule_resolution["is_follow_up"]:
+        return resolution
+
+    validated_plan = call_wikipedia_query_planner(message, history, model)
+    if not validated_plan:
+        return resolution
+
+    resolution.update(
+        {
+            "active_topic": validated_plan["active_topic"] or resolution["active_topic"],
+            "retrieval_query": validated_plan["retrieval_queries"][0],
+            "retrieval_queries": validated_plan["retrieval_queries"],
+            "reason": f"planner:{validated_plan['reason']}",
+            "standalone_question": validated_plan["standalone_question"],
+            "active_entities": validated_plan["active_entities"],
+            "planner_used": True,
+        }
+    )
+    return resolution
